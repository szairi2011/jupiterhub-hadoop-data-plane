{
  "_comment": "Phase 4 (KubeSpawner) variant of config.json.",
  "_comment2": "'livy' resolves via hostAliases injected by KubeSpawner (see helm-values.yaml).",
  "_comment3": "The kind node must be on the compose spark-net: phase4-up.ps1 runs",
  "_comment4": "  docker network connect learn-jupyterhub-with-livy_spark-net jhub-control-plane",
  "kernel_python_credentials": {
    "url": "http://livy:8998",
    "auth": "None",
    "username": "",
    "password": ""
  },
  "kernel_scala_credentials": {
    "url": "http://livy:8998",
    "auth": "None",
    "username": "",
    "password": ""
  },
  "session_configs": {
    "driverMemory": "1G",
    "driverCores": 1,
    "executorMemory": "1G",
    "executorCores": 1,
    "numExecutors": 1,
    "conf": {
      "spark.sql.catalogImplementation": "hive",
      "spark.hadoop.hive.metastore.uris": "thrift://hive-metastore:9083"
    }
  },
  "use_auto_viz": true,
  "coerce_dataframe": true,
  "max_results_sql": 2500,
  "pyspark_dataframe_encoding": "utf-8",
  "heartbeat_timeout": 60,
  "livy_session_waiting_timeout": 120,
  "livy_session_startup_timeout_seconds": 300,
  "livy_server_heartbeat_timeout": 0,
  "cleanup_all_sessions_on_exit": true,
  "shutdown_session_on_spark_statement_errors": false,
  "all_errors_are_fatal": false,
  "wait_for_idle_timeout": 120
}
